# LegacyBridge ULTRA — Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (get from https://aistudio.google.com)
GOOGLE_API_KEY=your_gemini_api_key_here

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here

# Path to GCP service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./service_account.json

# Green Mode — set to true to enable carbon-optimized narration
GREEN_MODE=false

# GCS bucket name for training video storage
GCS_BUCKET=legacybridge-training-videos

# Virtual display (set automatically by Dockerfile, leave as :99)
DISPLAY=:99

# Frontend WebSocket URL (update after Cloud Run deployment)
VITE_WS_URL=ws://localhost:8080
